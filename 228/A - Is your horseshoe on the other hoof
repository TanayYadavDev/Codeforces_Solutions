#include <bits/stdc++.h>
using namespace std;
 
int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
 
    vector<long long> a(4);
    int count = 0;
    for (int i = 0; i < 4; i++) {
        cin >> a[i];
        for (int j = 0; j <= i; j++) {
            if (i != j && a[i] == a[j]) {
                count++;
                break;
            }
        }
    }
 
    cout << count << "
";
 
    return 0;
}